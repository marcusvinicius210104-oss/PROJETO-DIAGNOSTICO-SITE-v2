<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diagnóstico Empresarial Estratégico — R$197</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--cream:#F5F0E8;--dark:#1A1208;--gold:#C9973A;--gold-light:#E8B84B;--warm-gray:#6B6355;--paper:#EDE7D9;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--cream);color:var(--dark);font-family:'DM Sans',sans-serif;overflow-x:hidden;}

/* HERO */
.hero{min-height:100vh;background:var(--dark);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 24px 60px;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 55% at 50% 25%,rgba(201,151,58,.18),transparent 70%);pointer-events:none;}
.badge{display:inline-flex;align-items:center;gap:8px;background:rgba(201,151,58,.12);border:1px solid rgba(201,151,58,.35);border-radius:100px;padding:6px 18px;font-size:12px;font-weight:500;color:var(--gold-light);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:32px;}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(36px,6vw,72px);font-weight:900;color:#fff;text-align:center;line-height:1.05;max-width:820px;}
.hero h1 em{font-style:italic;color:var(--gold-light);}
.hero-sub{margin-top:22px;font-size:clamp(15px,1.8vw,18px);color:rgba(255,255,255,.55);text-align:center;max-width:540px;line-height:1.7;font-weight:300;}
.price-block{margin-top:44px;display:flex;flex-direction:column;align-items:center;gap:6px;}
.price-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--warm-gray);}
.price-num{font-family:'Playfair Display',serif;font-size:60px;font-weight:700;color:#fff;line-height:1;}
.price-num sup{font-size:26px;color:var(--gold);vertical-align:super;}
.price-note{font-size:13px;color:rgba(255,255,255,.3);}
.cta-hero{margin-top:32px;background:var(--gold);color:var(--dark);font-weight:600;font-size:16px;padding:17px 46px;border:none;border-radius:4px;cursor:pointer;letter-spacing:.4px;transition:all .2s;}
.cta-hero:hover{background:var(--gold-light);transform:translateY(-2px);}
.trust{margin-top:26px;display:flex;gap:22px;flex-wrap:wrap;justify-content:center;}
.trust span{display:flex;align-items:center;gap:6px;font-size:13px;color:rgba(255,255,255,.4);}
.trust span::before{content:'✓';color:var(--gold);font-weight:700;}

/* INCLUI */
.includes{background:var(--paper);padding:80px 0;}
.includes>div{max-width:1080px;margin:0 auto;padding:0 24px;}
.sec-label{font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:14px;}
.sec-title{font-family:'Playfair Display',serif;font-size:clamp(28px,3.8vw,46px);font-weight:700;line-height:1.15;max-width:580px;color:var(--dark);}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2px;margin-top:44px;background:rgba(26,18,8,.08);}
.card{background:var(--paper);padding:34px 30px;}
.card-num{font-family:'Playfair Display',serif;font-size:46px;font-weight:900;color:rgba(201,151,58,.2);line-height:1;margin-bottom:14px;}
.card-title{font-weight:600;font-size:16px;margin-bottom:8px;color:var(--dark);}
.card-desc{font-size:14px;color:var(--warm-gray);line-height:1.65;}

/* PARA QUEM */
.pq{background:#F5F0E8;padding:80px 0;}
.pq>div{max-width:1080px;margin:0 auto;padding:0 24px;}
.pq-list{margin-top:36px;border-top:2px solid rgba(201,151,58,.25);}
.pq-item{display:flex;align-items:center;gap:20px;padding:22px 0;border-bottom:1px solid rgba(26,18,8,.1);}
.pq-icon{font-size:24px;width:52px;height:52px;background:#EDE7D9;border:1px solid rgba(201,151,58,.35);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.pq-item span{font-size:17px;color:#1A1208;font-family:'DM Sans',sans-serif;}
.pq-cta{margin-top:48px;display:flex;flex-direction:column;align-items:flex-start;gap:12px;}

/* MODAL */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;align-items:center;justify-content:center;padding:16px;}
.overlay.open{display:flex;}
.modal{background:var(--dark);border:1px solid rgba(255,255,255,.08);border-radius:12px;width:100%;max-width:680px;max-height:90vh;overflow-y:auto;position:relative;}
.modal-close{position:sticky;top:0;right:0;float:right;background:rgba(255,255,255,.06);border:none;color:rgba(255,255,255,.5);font-size:18px;width:38px;height:38px;border-radius:50%;cursor:pointer;margin:14px 14px 0 0;display:flex;align-items:center;justify-content:center;z-index:10;}
.modal-body{padding:28px 32px 36px;clear:both;}
@media(max-width:540px){.modal-body{padding:20px 18px 28px;}}

/* STEPS */
.prog{height:2px;background:rgba(255,255,255,.07);border-radius:1px;overflow:hidden;margin-bottom:28px;}
.prog-fill{height:100%;background:var(--gold);border-radius:1px;transition:width .4s;}
.tabs{display:flex;border-bottom:2px solid rgba(255,255,255,.07);margin-bottom:24px;}
.tab{padding:10px 16px 12px;font-size:12px;font-weight:500;color:rgba(255,255,255,.28);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .2s;letter-spacing:.3px;}
.tab.active{color:var(--gold-light);border-bottom-color:var(--gold-light);}
.step{display:none;}
.step.active{display:block;}
.step-title{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#fff;margin-bottom:6px;}
.step-sub{font-size:13px;color:rgba(255,255,255,.4);margin-bottom:24px;line-height:1.6;}

/* CAMPOS */
.fg{margin-bottom:16px;}
.fg label{display:block;font-size:12px;font-weight:500;color:rgba(255,255,255,.45);margin-bottom:7px;letter-spacing:.3px;}
.fg label em{color:var(--gold);font-style:normal;}
.fg input,.fg select,.fg textarea{width:100%;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:4px;padding:12px 14px;font-family:'DM Sans',sans-serif;font-size:14px;color:#fff;outline:none;transition:border-color .2s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--gold);background:rgba(201,151,58,.05);}
.fg select option{background:#1a1208;}
.fg textarea{resize:vertical;min-height:88px;}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:500px){.row2{grid-template-columns:1fr;}}

/* BOTÕES */
.btn-next{background:var(--gold);border:none;color:var(--dark);padding:13px 32px;border-radius:4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;transition:all .2s;display:inline-flex;align-items:center;gap:8px;}
.btn-next:hover{background:var(--gold-light);transform:translateY(-1px);}
.btn-next:disabled{opacity:.45;cursor:not-allowed;transform:none;}
.btn-back{background:transparent;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.45);padding:12px 24px;border-radius:4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:14px;transition:all .2s;}
.btn-back:hover{border-color:rgba(255,255,255,.35);color:rgba(255,255,255,.75);}
.nav{display:flex;justify-content:space-between;align-items:center;margin-top:24px;}

/* RESUMO */
.resumo{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:8px;padding:22px;margin-bottom:20px;}
.resumo-label{font-size:11px;color:rgba(255,255,255,.3);letter-spacing:1px;text-transform:uppercase;margin-bottom:14px;}
.resumo-row{display:flex;gap:12px;margin-bottom:8px;font-size:13px;}
.resumo-key{color:rgba(255,255,255,.3);min-width:120px;flex-shrink:0;}
.resumo-val{color:rgba(255,255,255,.75);}

/* PIX */
.pix-box{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:28px;text-align:center;}
.pix-qr img{width:200px;height:200px;border-radius:6px;margin:0 auto 16px;display:block;background:#fff;padding:8px;}
.pix-label{font-size:11px;color:rgba(255,255,255,.35);letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;}
.pix-code{font-size:11px;color:rgba(255,255,255,.6);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:4px;padding:12px;word-break:break-all;text-align:left;line-height:1.6;margin-bottom:12px;cursor:pointer;}
.pix-code:hover{background:rgba(255,255,255,.08);}
.btn-copy{background:transparent;border:1px solid var(--gold);color:var(--gold);padding:10px 22px;border-radius:4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;transition:all .2s;margin-bottom:16px;}
.btn-copy:hover{background:rgba(201,151,58,.1);}
.pix-timer{font-size:13px;color:rgba(255,255,255,.35);margin-bottom:12px;}
.pix-timer strong{color:var(--gold-light);}
.pix-status{padding:12px;border-radius:6px;font-size:14px;font-weight:500;text-align:center;}
.pix-status.waiting{background:rgba(201,151,58,.08);color:var(--gold-light);border:1px solid rgba(201,151,58,.2);}
.pix-status.paid{background:rgba(45,122,79,.15);color:#6de8a0;border:1px solid rgba(45,122,79,.3);}
.btn-japarei{margin-top:14px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.6);padding:10px 22px;border-radius:4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;display:block;width:100%;transition:all .2s;}
.btn-japarei:hover{background:rgba(255,255,255,.1);}

/* RELATÓRIO */
.rel-header{display:flex;align-items:center;gap:14px;padding-bottom:20px;border-bottom:1px solid rgba(255,255,255,.08);margin-bottom:24px;}
.rel-icon{width:44px;height:44px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.rel-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:#fff;}
.rel-sub{font-size:12px;color:rgba(255,255,255,.35);margin-top:3px;}
.rel-content{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:8px;padding:24px;color:rgba(255,255,255,.82);font-size:14px;line-height:1.85;}
.rel-content h2,.rel-content h3{font-family:'Playfair Display',serif;color:var(--gold-light);margin:20px 0 8px;}
.rel-content h2:first-child{margin-top:0;}
.btn-dl{margin-top:18px;display:inline-flex;align-items:center;gap:8px;background:transparent;border:1px solid var(--gold);color:var(--gold);padding:10px 24px;border-radius:4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;transition:all .2s;}
.btn-dl:hover{background:rgba(201,151,58,.1);}

/* LOADING */
.loading{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px;gap:18px;}
.dots{display:flex;gap:8px;}
.dot{width:9px;height:9px;background:var(--gold);border-radius:50%;animation:dp 1.4s ease infinite;}
.dot:nth-child(2){animation-delay:.2s;}.dot:nth-child(3){animation-delay:.4s;}
@keyframes dp{0%,100%{opacity:.25;transform:scale(.7)}50%{opacity:1;transform:scale(1)}}
.loading-text{font-size:14px;color:rgba(255,255,255,.4);}
.erro{background:rgba(255,80,80,.07);border:1px solid rgba(255,80,80,.2);border-radius:6px;padding:14px;color:#ff9090;font-size:13px;margin-top:14px;line-height:1.6;}

footer{background:var(--dark);border-top:1px solid rgba(255,255,255,.05);padding:32px 24px;text-align:center;font-size:12px;color:rgba(255,255,255,.18);}
</style>
</head>
<body>

<!-- HERO -->
<div class="hero">
  <div class="badge">Diagnóstico Estratégico Empresarial</div>
  <h1>Descubra o que está <em>travando</em> o crescimento do seu negócio</h1>
  <p class="hero-sub">Relatório personalizado com IA avançada — análise de marketing, operações, presença digital e plano de ação em 90 dias.</p>
  <div class="price-block">
    <div class="price-label">Investimento único</div>
    <div class="price-num"><sup>R$</sup>197</div>
    <div class="price-note">Pagamento via PIX • Relatório entregue na hora</div>
  </div>
  <button class="cta-hero" onclick="abrirModal()">Quero meu diagnóstico agora →</button>
  <div class="trust">
    <span>Análise personalizada</span>
    <span>Plano de ação 90 dias</span>
    <span>Entrega imediata</span>
    <span>Pagamento seguro</span>
  </div>
</div>

<!-- INCLUI -->
<div class="includes">
  <div>
    <div class="sec-label">O que você recebe</div>
    <div class="sec-title">Um raio-X completo do seu negócio</div>
    <div class="cards">
      <div class="card"><div class="card-num">01</div><div class="card-title">Presença Digital</div><div class="card-desc">Instagram, Google, site e WhatsApp — onde você perde clientes antes do primeiro contato.</div></div>
      <div class="card"><div class="card-num">02</div><div class="card-title">Diagnóstico de Atendimento</div><div class="card-desc">Gargalos no processo de captação e conversão — do primeiro contato ao fechamento.</div></div>
      <div class="card"><div class="card-num">03</div><div class="card-title">Análise da Concorrência</div><div class="card-desc">O que seus concorrentes fazem melhor — e onde você tem vantagem sem saber.</div></div>
      <div class="card"><div class="card-num">04</div><div class="card-title">Plano de Ação 90 Dias</div><div class="card-desc">Prioridades claras com ações de curto, médio e longo prazo para implementar hoje.</div></div>
    </div>
  </div>
</div>

<!-- PARA QUEM -->
<div class="pq">
  <div>
    <div class="sec-label">Para quem é</div>
    <div class="sec-title">Feito para negócios locais que querem crescer de verdade</div>
    <div class="pq-list">
      <div class="pq-item"><div class="pq-icon">🍽️</div><span>Donos de restaurantes, lanchonetes e delivery</span></div>
      <div class="pq-item"><div class="pq-icon">🏥</div><span>Clínicas, consultórios médicos e odontológicos</span></div>
      <div class="pq-item"><div class="pq-icon">🛍️</div><span>Lojas físicas e comércio local</span></div>
      <div class="pq-item"><div class="pq-icon">💆</div><span>Salões, barbearias e centros estéticos</span></div>
      <div class="pq-item"><div class="pq-icon">🔧</div><span>Prestadores de serviço e pequenas empresas</span></div>
    </div>
    <div class="pq-cta">
      <button class="cta-hero" onclick="abrirModal()">Quero meu diagnóstico agora →</button>
      <span style="font-size:13px;color:#6B6355;">R$197 • PIX • Relatório na hora</span>
    </div>
  </div>
</div>

<!-- MODAL -->
<div class="overlay" id="overlay" onclick="fecharSeOverlay(event)">
  <div class="modal">
    <button class="modal-close" onclick="fecharModal()">✕</button>
    <div class="modal-body">
      <div class="prog"><div class="prog-fill" id="progFill" style="width:25%"></div></div>
      <div class="tabs">
        <div class="tab active" id="tab1">1. Negócio</div>
        <div class="tab" id="tab2">2. Marketing</div>
        <div class="tab" id="tab3">3. Desafios</div>
        <div class="tab" id="tab4">4. Pagamento</div>
      </div>

      <!-- STEP 1 -->
      <div class="step active" id="s1">
        <div class="step-title">Sobre o seu negócio</div>
        <div class="step-sub">Quanto mais detalhes, mais preciso o diagnóstico.</div>
        <div class="row2">
          <div class="fg"><label>Nome do negócio <em>*</em></label><input id="f_nome" placeholder="Ex: Restaurante Sabor do Norte"></div>
          <div class="fg"><label>Segmento <em>*</em></label>
            <select id="f_seg"><option value="">Selecione...</option><option>Restaurante / Alimentação</option><option>Clínica / Saúde</option><option>Loja / Varejo</option><option>Salão / Estética</option><option>Serviços Gerais</option><option>Outro</option></select>
          </div>
        </div>
        <div class="row2">
          <div class="fg"><label>Cidade / Estado <em>*</em></label><input id="f_cidade" placeholder="Ex: Natal, RN"></div>
          <div class="fg"><label>Tempo de mercado</label><select id="f_tempo"><option value="">Selecione...</option><option>Menos de 1 ano</option><option>1 a 3 anos</option><option>3 a 5 anos</option><option>Mais de 5 anos</option></select></div>
        </div>
        <div class="row2">
          <div class="fg"><label>Funcionários</label><select id="f_func"><option value="">Selecione...</option><option>Só eu (MEI)</option><option>2 a 5</option><option>6 a 15</option><option>16 a 50</option><option>Mais de 50</option></select></div>
          <div class="fg"><label>Faturamento mensal</label><select id="f_fat"><option value="">Prefiro não informar</option><option>Até R$10 mil</option><option>R$10 mil a R$50 mil</option><option>R$50 mil a R$150 mil</option><option>R$150 mil a R$500 mil</option><option>Acima de R$500 mil</option></select></div>
        </div>
        <div class="nav"><div></div><button class="btn-next" onclick="ir(2)">Próximo →</button></div>
      </div>

      <!-- STEP 2 -->
      <div class="step" id="s2">
        <div class="step-title">Marketing e captação</div>
        <div class="step-sub">Como seu negócio atrai clientes hoje.</div>
        <div class="fg"><label>Quais canais você usa para divulgar? <em>*</em></label><textarea id="f_canais" placeholder="Instagram, WhatsApp, Google, panfletagem, indicação..."></textarea></div>
        <div class="fg"><label>Investe em anúncios pagos?</label><select id="f_trafego"><option value="">Selecione...</option><option>Não invisto nada</option><option>Já tentei mas sem resultado</option><option>Invisto até R$500/mês</option><option>Invisto R$500 a R$2.000/mês</option><option>Invisto mais de R$2.000/mês</option></select></div>
        <div class="fg"><label>Como a maioria dos clientes chega até você?</label><textarea id="f_captacao" placeholder="Ex: maioria por indicação, alguns pelo Instagram..."></textarea></div>
        <div class="fg"><label>Presença online</label><select id="f_online"><option value="">Selecione...</option><option>Não tenho nenhum</option><option>Só Google Meu Negócio</option><option>Só site</option><option>Tenho os dois</option></select></div>
        <div class="nav"><button class="btn-back" onclick="ir(1)">← Voltar</button><button class="btn-next" onclick="ir(3)">Próximo →</button></div>
      </div>

      <!-- STEP 3 -->
      <div class="step" id="s3">
        <div class="step-title">Desafios e objetivos</div>
        <div class="step-sub">Seja honesto — isso define a qualidade do diagnóstico.</div>
        <div class="fg"><label>Qual é o maior desafio do seu negócio hoje? <em>*</em></label><textarea id="f_desafio" style="min-height:110px;" placeholder="Ex: falta de clientes novos, equipe desengajada..."></textarea></div>
        <div class="fg"><label>O que você já tentou para crescer?</label><textarea id="f_tentativas" placeholder="Ex: contratei social media, rodei anúncios..."></textarea></div>
        <div class="fg"><label>O que quer alcançar nos próximos 6 meses?</label><textarea id="f_objetivos" placeholder="Ex: dobrar clientes, abrir segunda unidade..."></textarea></div>
        <div class="nav"><button class="btn-back" onclick="ir(2)">← Voltar</button><button class="btn-next" onclick="ir(4)">Próximo →</button></div>
      </div>

      <!-- STEP 4: PAGAMENTO -->
      <div class="step" id="s4">
        <div class="step-title">Pagamento via PIX</div>
        <div class="step-sub">Preencha seus dados para gerar o QR Code.</div>
        <div class="row2">
          <div class="fg"><label>Nome completo <em>*</em></label><input id="f_pnome" placeholder="Como no CPF"></div>
          <div class="fg"><label>CPF <em>*</em></label><input id="f_cpf" placeholder="000.000.000-00" maxlength="14" oninput="maskCPF(this)"></div>
        </div>
        <div class="row2">
          <div class="fg"><label>E-mail <em>*</em></label><input id="f_email" type="email" placeholder="seu@email.com"></div>
          <div class="fg"><label>WhatsApp</label><input id="f_tel" placeholder="(84) 99999-9999" maxlength="15" oninput="maskTel(this)"></div>
        </div>
        <div class="resumo">
          <div class="resumo-label">Resumo do pedido</div>
          <div class="resumo-row"><span class="resumo-key">Negócio</span><span class="resumo-val" id="r_nome">—</span></div>
          <div class="resumo-row"><span class="resumo-key">Segmento</span><span class="resumo-val" id="r_seg">—</span></div>
          <div class="resumo-row"><span class="resumo-key">Cidade</span><span class="resumo-val" id="r_cidade">—</span></div>
          <div class="resumo-row" style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(255,255,255,.07);">
            <span class="resumo-key" style="color:rgba(255,255,255,.5);">Total</span>
            <span class="resumo-val" style="font-weight:600;font-size:16px;color:var(--gold-light);">R$ 197,00</span>
          </div>
        </div>
        <div id="erroStep4"></div>
        <div class="nav"><button class="btn-back" onclick="ir(3)">← Voltar</button><button class="btn-next" id="btnPix" onclick="gerarPix()">Gerar PIX →</button></div>
      </div>

      <!-- STEP 5: PIX -->
      <div class="step" id="s5">
        <div class="step-title">Escaneie o QR Code</div>
        <div class="step-sub">Pague R$197 via PIX — confirmado o pagamento, seu relatório é gerado automaticamente.</div>
        <div class="pix-box">
          <div class="pix-qr"><img id="pixImg" src="" alt="QR Code PIX"></div>
          <div class="pix-label">Ou copie o código PIX</div>
          <div class="pix-code" id="pixCode" onclick="copiar()">—</div>
          <button class="btn-copy" onclick="copiar()">📋 Copiar código PIX</button>
          <div class="pix-timer" id="pixTimer"></div>
          <div class="pix-status waiting" id="pixStatus">⏳ Aguardando pagamento...</div>
          <button class="btn-japarei" onclick="gerarRelatorio()">✅ Já paguei — gerar meu relatório</button>
        </div>
      </div>

      <!-- RELATÓRIO -->
      <div id="secRelatorio" style="display:none;">
        <div class="rel-header">
          <div class="rel-icon">✦</div>
          <div>
            <div class="rel-title">Diagnóstico Estratégico</div>
            <div class="rel-sub" id="relSub">—</div>
          </div>
        </div>
        <div class="rel-content" id="relContent">
          <div class="loading"><div class="dots"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div><div class="loading-text">Gerando seu diagnóstico...</div></div>
        </div>
        <button class="btn-dl" onclick="baixar()">⬇ Baixar relatório</button>
      </div>

    </div>
  </div>
</div>

<footer>
  <p>© 2025 — Diagnóstico Empresarial Estratégico</p>
  <p style="margin-top:6px;">Pagamento seguro via PIX • Powered by IA Avançada</p>
</footer>

<script>
// ── ESTADO ──
let stepAtual = 1;
let pixId = null;
let pixInterval = null;
let relTexto = '';

// ── MODAL ──
function abrirModal(){ document.getElementById('overlay').classList.add('open'); document.body.style.overflow='hidden'; }
function fecharModal(){ document.getElementById('overlay').classList.remove('open'); document.body.style.overflow=''; if(pixInterval) clearInterval(pixInterval); }
function fecharSeOverlay(e){ if(e.target===document.getElementById('overlay')) fecharModal(); }

// ── NAVEGAÇÃO ──
function ir(n){
  if(!validar(stepAtual)) return;
  document.getElementById('s'+stepAtual).classList.remove('active');
  document.getElementById('tab'+stepAtual)?.classList.remove('active');
  stepAtual = n;
  document.getElementById('s'+stepAtual).classList.add('active');
  document.getElementById('tab'+stepAtual)?.classList.add('active');
  const p={1:25,2:50,3:75,4:100};
  document.getElementById('progFill').style.width=(p[n]||100)+'%';
  if(n===4) preencherResumo();
  document.querySelector('.modal').scrollTop=0;
}

function validar(n){
  if(n===1){
    if(!g('f_nome')){ alerta('f_nome','Informe o nome do negócio'); return false; }
    if(!g('f_seg')){ alerta('f_seg','Selecione o segmento'); return false; }
    if(!g('f_cidade')){ alerta('f_cidade','Informe a cidade'); return false; }
  }
  if(n===2){ if(!g('f_canais')){ alerta('f_canais','Descreva os canais usados'); return false; } }
  if(n===3){ if(!g('f_desafio')){ alerta('f_desafio','Descreva o maior desafio'); return false; } }
  return true;
}

function g(id){ return document.getElementById(id).value.trim(); }

function alerta(id, msg){
  const el=document.getElementById(id);
  el.style.borderColor='#ff6b6b'; el.focus();
  setTimeout(()=>el.style.borderColor='',2500);
  const t=document.createElement('div');
  t.style.cssText='position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#ff6b6b;color:#fff;padding:10px 20px;border-radius:6px;font-size:13px;z-index:9999;font-family:DM Sans,sans-serif;';
  t.textContent=msg; document.body.appendChild(t); setTimeout(()=>t.remove(),2500);
}

function preencherResumo(){
  document.getElementById('r_nome').textContent = g('f_nome')||'—';
  document.getElementById('r_seg').textContent  = g('f_seg')||'—';
  document.getElementById('r_cidade').textContent = g('f_cidade')||'—';
}

// ── MÁSCARAS ──
function maskCPF(el){
  let s=el.value.replace(/\D/g,'').substring(0,11);
  s=s.replace(/(\d{3})(\d)/,'$1.$2').replace(/(\d{3})(\d)/,'$1.$2').replace(/(\d{3})(\d{1,2})$/,'$1-$2');
  el.value=s;
}
function maskTel(el){
  let s=el.value.replace(/\D/g,'').substring(0,11);
  s=s.length>10?s.replace(/(\d{2})(\d{5})(\d{4})/,'($1) $2-$3'):s.replace(/(\d{2})(\d{4})(\d{4})/,'($1) $2-$3');
  el.value=s;
}

// ── GERAR PIX ──
async function gerarPix(){
  const nome  = g('f_pnome');
  const cpf   = g('f_cpf');
  const email = g('f_email');
  if(!nome){ alerta('f_pnome','Informe seu nome'); return; }
  if(!cpf||cpf.length<14){ alerta('f_cpf','CPF inválido'); return; }
  if(!email){ alerta('f_email','Informe o e-mail'); return; }

  const btn = document.getElementById('btnPix');
  btn.disabled=true; btn.textContent='Gerando PIX...';
  document.getElementById('erroStep4').innerHTML='';

  try {
    const res = await fetch('/api/pix-criar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nome, email, cpf })
    });

    const data = await res.json();
    console.log('[PIX] Resposta:', data);

    if(!res.ok) throw new Error(data.error || JSON.stringify(data));
    if(!data.qr_code) throw new Error('QR Code não retornado pela API');

    pixId = data.id;

    // Mostrar step PIX
    document.getElementById('s4').classList.remove('active');
    document.getElementById('s5').classList.add('active');

    // QR Code
    if(data.qr_code_base64){
      document.getElementById('pixImg').src = 'data:image/png;base64,'+data.qr_code_base64;
    } else {
      document.getElementById('pixImg').style.display='none';
    }
    document.getElementById('pixCode').textContent = data.qr_code;

    // Timer 30 minutos
    let seg = 1800;
    const timer = setInterval(()=>{
      seg--;
      const m=Math.floor(seg/60), s=seg%60;
      document.getElementById('pixTimer').innerHTML = `Expira em <strong>${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}</strong>`;
      if(seg<=0) clearInterval(timer);
    },1000);

    // Polling automático
    pixInterval = setInterval(verificarPagamento, 5000);

  } catch(err){
    console.error('[PIX] Erro:', err);
    document.getElementById('erroStep4').innerHTML = `<div class="erro">❌ ${err.message}</div>`;
  } finally {
    btn.disabled=false; btn.textContent='Gerar PIX →';
  }
}

// ── VERIFICAR PAGAMENTO ──
async function verificarPagamento(){
  if(!pixId) return;
  try {
    const res = await fetch(`/api/pix-verificar?id=${pixId}`);
    const data = await res.json();
    console.log('[PIX STATUS]', data.status);
    if(data.status === 'approved'){
      clearInterval(pixInterval);
      document.getElementById('pixStatus').className='pix-status paid';
      document.getElementById('pixStatus').textContent='✅ Pagamento confirmado! Gerando relatório...';
      setTimeout(()=>gerarRelatorio(), 1500);
    }
  } catch(e){ console.warn('[PIX STATUS] erro:', e.message); }
}

// ── COPIAR PIX ──
function copiar(){
  const code = document.getElementById('pixCode').textContent;
  navigator.clipboard.writeText(code).then(()=>{
    const btn=document.querySelector('.btn-copy');
    btn.textContent='✅ Copiado!';
    setTimeout(()=>btn.textContent='📋 Copiar código PIX',2000);
  });
}

// ── GERAR RELATÓRIO ──
async function gerarRelatorio(){
  if(pixInterval) clearInterval(pixInterval);
  document.getElementById('s5').classList.remove('active');
  document.getElementById('secRelatorio').style.display='block';
  document.getElementById('relSub').textContent = `${g('f_nome')} • ${g('f_seg')} • ${g('f_cidade')}`;

  try {
    const res = await fetch('/api/relatorio', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nome: g('f_nome'), segmento: g('f_seg'), cidade: g('f_cidade'),
        tempo: g('f_tempo'), funcionarios: g('f_func'), faturamento: g('f_fat'),
        canais: g('f_canais'), trafego: g('f_trafego'), captacao: g('f_captacao'),
        online: g('f_online'), desafio: g('f_desafio'),
        tentativas: g('f_tentativas'), objetivos: g('f_objetivos')
      })
    });

    const data = await res.json();
    if(!res.ok) throw new Error(data.error || 'Erro ao gerar relatório');

    relTexto = data.relatorio;
    document.getElementById('relContent').innerHTML = renderMd(relTexto);

  } catch(err){
    document.getElementById('relContent').innerHTML = `<div class="erro">❌ ${err.message}</div>`;
  }
}

function renderMd(txt){
  return txt
    .replace(/## (.*)/g,'<h2>$1</h2>')
    .replace(/### (.*)/g,'<h3>$1</h3>')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/^- (.*)/gm,'<li>$1</li>')
    .replace(/\n\n/g,'<br><br>')
    .replace(/\n/g,'<br>');
}

function baixar(){
  if(!relTexto) return;
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([relTexto],{type:'text/plain;charset=utf-8'}));
  a.download=`diagnostico-${g('f_nome').replace(/\s+/g,'-').toLowerCase()}.txt`;
  a.click();
}
</script>
</body>
</html>
